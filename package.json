{
  "name": "check-yourself",
  "version": "1.0.0",
  "description": "Track your spending temptations and make better choices",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --publish never",
    "release": "npm run dist && node scripts/generate-release-hash.js"
  },
  "build": {
    "appId": "com.checkyourself.app",
    "productName": "Check Yourself",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "artifactName": "Check-Yourself-${version}-${arch}.${ext}",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.lifestyle"
    },
    "dmg": {
      "title": "Check Yourself"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0"
  }
}
